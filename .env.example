# ── Cloudflare credentials ────────────────────────────────────────────────────
#
# CF_API_TOKEN — Runtime admin token used by the MCP server to call Cloudflare APIs
#   Permissions required:
#     Zone > DNS > Edit
#     Account > Zero Trust > Edit
#   Create at: https://dash.cloudflare.com/profile/api-tokens
#   Recommended: set a 90-day expiry at creation time
#
CF_API_TOKEN=your_cloudflare_api_token_here

# CF_ACCOUNT_ID — Your Cloudflare account ID
#   Find at: https://dash.cloudflare.com (right sidebar > Account ID)
#
CF_ACCOUNT_ID=your_account_id_here

# ── MCP server auth ───────────────────────────────────────────────────────────
#
# MCP_BEARER_TOKEN — Shared secret required by all MCP clients connecting to this server
#   Generate with: openssl rand -hex 32
#   Pass in Claude Code settings as: --header "Authorization: Bearer <token>"
#
MCP_BEARER_TOKEN=your_bearer_token_here

# ── Server config ─────────────────────────────────────────────────────────────
#
# MCP_PORT — Port the HTTP server listens on inside the container (default: 3000)
#
MCP_PORT=3000
